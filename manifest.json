{
    "manifest_version": 3,
    "name": "DevLens",
    "version": "1.0",
    "description": "A design and tech snapshot of a webpage on demand.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://api.openai.com/*"
    ],
    "background": {
        "service_worker": "src/background.js"
    },
    "action": {
        "default_title": "Activate DevLens"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "src/styles.css",
                "src/ui.js",
                "src/detector.js",
                "src/scanner.js",
                "src/clipboard.js",
                "src/ripper.js",
                "src/store.js",
                "src/eventBus.js",
                "src/styleEngine.js",
                "src/irBuilder.js",
                "src/styleNormalizer.js",
                "src/componentDetector.js",
                "src/codegen/reactGenerator.js",
                "src/codegen/tailwindMapper.js",
                "src/codegen/aiRefiner.js",
                "src/mainWorld.js",
                "src/dataInspector.js",
                "src/layoutInspector.js",
                "src/propExtractor.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}